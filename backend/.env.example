# ---------------------------------------------------------------------------
# Theft Detection – Backend environment configuration
# Copy this file to .env and fill in your real values.
# ---------------------------------------------------------------------------

# Absolute path to backend root (auto-detected if omitted)
# THEFT_BASE_DIR=/path/to/backend

# Directory where processed videos are stored (relative to base_dir)
THEFT_OUTPUTS_DIR=outputs

# Behaviour classification model (relative to base_dir or absolute path)
THEFT_BEHAVIOR_MODEL=models/theft_modelss.keras

# YOLOv8 model name / path
THEFT_YOLO_MODEL=yolov8n.pt

# Tracker config (bytetrack.yaml | botsort.yaml)
THEFT_TRACKER_CFG=bytetrack.yaml

# COCO class IDs
THEFT_PERSON_CLASS_ID=0
THEFT_CUP_CLASS_ID=41

# Detection confidence threshold
THEFT_YOLO_CONF=0.25

# Run classifier every N frames (higher = faster, lower = more accurate)
THEFT_CLASSIFY_EVERY_N_FRAMES=15

# Save annotated output video by default
THEFT_SAVE_VIDEO_DEFAULT=true

# CORS allowed origins – comma-separated (use * to allow all in development)
# Example: THEFT_CORS_ORIGINS=http://localhost:5500,https://yourfrontend.com
THEFT_CORS_ORIGINS=*
