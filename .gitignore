# =============================================================================
# Theft Detection – .gitignore
# =============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ---------- Virtual environments ----------
.venv/
venv/
env/
ENV/

# ---------- Environment / secrets ----------
.env
*.env.local

# ---------- Model weights (large binary files) ----------
# Uncomment these lines if you do NOT want to track model weights in Git.
# Use Git LFS (https://git-lfs.com) for large files instead.
# backend/models/*.keras
# backend/models/*.pth
# backend/models/*.pt
# backend/yolov8n.pt

# ---------- Outputs / uploads ----------
backend/outputs/
outputs/

# ---------- Test videos ----------
test/

# ---------- Logs ----------
*.log
logs/

# ---------- OS / IDE ----------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---------- Coverage / testing ----------
.coverage
htmlcov/
.pytest_cache/
